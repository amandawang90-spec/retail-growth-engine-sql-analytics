-- PHASE 4B: REVENUE AT RISK & SEGMENT ATTRITION (90-DAY)

DROP TABLE IF EXISTS new_revenue_at_risk_and_segment_attrition;

CREATE TABLE new_revenue_at_risk_and_segment_attrition AS

SELECT
    r.customer_segment,
    COUNT(r.customer_id)                                                        AS total_customers,
    SUM(c.is_churned)                                                           AS churned_count,
    COUNT(r.customer_id) - SUM(c.is_churned)                                   AS active_count,
    ROUND(SUM(c.is_churned)::NUMERIC / NULLIF(COUNT(r.customer_id), 0) * 100, 2) AS churn_rate_pct,
    ROUND(SUM(CASE WHEN c.is_churned = 1 THEN r.monetary ELSE 0 END)::NUMERIC, 2) AS total_revenue_lost,
    ROUND(
        SUM(CASE WHEN c.is_churned = 1 THEN r.monetary ELSE 0 END)::NUMERIC
        / NULLIF(SUM(c.is_churned), 0), 2
    )                                                                           AS avg_revenue_per_churned,
    ROUND(
        SUM(CASE WHEN c.is_churned = 1 THEN r.monetary ELSE 0 END)::NUMERIC * 100
        / SUM(SUM(CASE WHEN c.is_churned = 1 THEN r.monetary ELSE 0 END)::NUMERIC) OVER (),
        2
    )                                                                           AS pct_of_total_revenue_lost
FROM new_rfm_segment_analysis r
JOIN new_churned_or_not c ON r.customer_id = c.customer_id
GROUP BY r.customer_segment
ORDER BY total_revenue_lost DESC;

--Pivot for easier visualization

DROP TABLE IF EXISTS new_revenue_at_risk_pivot;

CREATE TABLE new_revenue_at_risk_pivot AS

SELECT customer_segment, 'Total Customers'        AS metric, total_customers::NUMERIC    AS value FROM new_revenue_at_risk_and_segment_attrition
UNION ALL
SELECT customer_segment, 'Churned Count'          AS metric, churned_count::NUMERIC      AS value FROM new_revenue_at_risk_and_segment_attrition
UNION ALL
SELECT customer_segment, 'Active Count'           AS metric, active_count::NUMERIC       AS value FROM new_revenue_at_risk_and_segment_attrition
UNION ALL
SELECT customer_segment, 'Churn Rate %'           AS metric, churn_rate_pct::NUMERIC     AS value FROM new_revenue_at_risk_and_segment_attrition
UNION ALL
SELECT customer_segment, 'Revenue Lost'           AS metric, total_revenue_lost::NUMERIC AS value FROM new_revenue_at_risk_and_segment_attrition
UNION ALL
SELECT customer_segment, 'Avg Revenue Churned'    AS metric, avg_revenue_per_churned::NUMERIC AS value FROM new_revenue_at_risk_and_segment_attrition
UNION ALL
SELECT customer_segment, 'Pct Revenue Lost'       AS metric, pct_of_total_revenue_lost::NUMERIC AS value FROM new_revenue_at_risk_and_segment_attrition
ORDER BY customer_segment, metric;
