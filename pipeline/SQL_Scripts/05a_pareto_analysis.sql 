-- PHASE 5A: PARETO ANALYSIS

DROP TABLE IF EXISTS new_pareto_analysis;

CREATE TABLE new_pareto_analysis AS
WITH customer_spending AS (
    SELECT
        customer_id,
        monetary::NUMERIC AS total_revenue
    FROM new_rfm_segment_analysis
),
totals AS (
    SELECT
        SUM(total_revenue)::NUMERIC AS grand_total,
        COUNT(customer_id)          AS total_customer_count
    FROM customer_spending
),
running_total_calc AS (
    SELECT
        cs.customer_id,
        cs.total_revenue,
        ROW_NUMBER() OVER (ORDER BY cs.total_revenue DESC)          AS customer_rank,
        SUM(cs.total_revenue) OVER (ORDER BY cs.total_revenue DESC) AS running_total
    FROM customer_spending cs
)
SELECT
    r.customer_id,
    r.customer_rank,
    t.total_customer_count,
    ROUND(r.total_revenue, 2)                                                  AS total_revenue,
    ROUND(r.customer_rank::NUMERIC / t.total_customer_count * 100, 2)         AS pct_of_customer_base,
    ROUND(r.running_total / t.grand_total * 100, 2)                           AS pct_of_total_revenue,
    CASE
        WHEN r.customer_rank::NUMERIC / t.total_customer_count <= 0.01 THEN 'Top 1%'
        WHEN r.customer_rank::NUMERIC / t.total_customer_count <= 0.05 THEN 'Top 5%'
        WHEN r.customer_rank::NUMERIC / t.total_customer_count <= 0.10 THEN 'Top 10%'
        WHEN r.customer_rank::NUMERIC / t.total_customer_count <= 0.20 THEN 'Top 20%'
        WHEN r.customer_rank::NUMERIC / t.total_customer_count <= 0.50 THEN 'Top 50%'
        ELSE 'Bottom 50%'
    END                                                                        AS pareto_bucket
FROM running_total_calc r
CROSS JOIN totals t
ORDER BY r.customer_rank ASC;

SELECT
    'pareto_bucket' AS pareto_bucket, 'customer_count' AS customer_count,
    'total_revenue' AS total_revenue, 'cumulative_pct' AS cumulative_pct
UNION ALL
SELECT pareto_bucket, COUNT(*)::TEXT, 
    ROUND(SUM(total_revenue)::NUMERIC, 2)::TEXT,
    ROUND(MAX(pct_of_total_revenue)::NUMERIC, 2)::TEXT
FROM new_pareto_analysis
GROUP BY pareto_bucket
ORDER BY 4 ASC;