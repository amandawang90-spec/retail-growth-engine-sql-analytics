-- PHASE 5B: PREDICTIVE CLV

DROP TABLE IF EXISTS new_predictive_clv_analysis;

CREATE TABLE new_predictive_clv_analysis AS
WITH date_range AS (
    SELECT 
        EXTRACT(days FROM (MAX(invoice_date) - MIN(invoice_date))) / 365.0 AS data_years
    FROM cleaned_retail_main
),
segment_aggregates AS (
    SELECT
        r.customer_segment,
        COUNT(r.customer_id)                                        AS total_customers,
        SUM(r.monetary) / NULLIF(SUM(r.frequency), 0)              AS avg_order_value,
        AVG(r.frequency) / d.data_years                            AS avg_annual_frequency,
        AVG(r.recency_days)                                         AS avg_recency_days,
        COUNT(
            CASE WHEN r.recency_days > 90 THEN 1 END
        )::NUMERIC / NULLIF(COUNT(r.customer_id), 0)               AS churn_rate
    FROM new_rfm_segment_analysis r
    CROSS JOIN date_range d
    GROUP BY r.customer_segment, d.data_years
),
adjusted AS (
    SELECT
        *,
        CASE
            -- If churn = 0, derive from actual recency behaviour
            WHEN churn_rate = 0    THEN avg_recency_days / 365.0
            -- Cap at 0.99 to avoid division issues
            WHEN churn_rate >= 1.0 THEN 0.99
            ELSE churn_rate
        END AS adjusted_churn_rate
    FROM segment_aggregates
)
SELECT
    customer_segment,
    total_customers,
    ROUND(avg_order_value::NUMERIC, 2)                              AS aov,
    ROUND(avg_annual_frequency::NUMERIC, 2)                         AS avg_annual_frequency,
    ROUND(avg_recency_days::NUMERIC, 0)                             AS avg_recency_days,
    ROUND(churn_rate::NUMERIC, 4)                                   AS raw_churn_rate,
    ROUND(adjusted_churn_rate::NUMERIC, 4)                          AS segment_churn_rate,
    ROUND((1 - adjusted_churn_rate)::NUMERIC, 4)                    AS retention_rate,
    ROUND((1 / adjusted_churn_rate)::NUMERIC, 2)                    AS avg_customer_lifespan_years,
    ROUND(
        (avg_order_value * avg_annual_frequency / adjusted_churn_rate)::NUMERIC,
        2
    )                                                               AS predicted_clv
FROM adjusted
ORDER BY predicted_clv DESC;

--Pivot for easier visualization

DROP TABLE IF EXISTS new_clv_pivot;

CREATE TABLE new_clv_pivot AS
WITH base AS (
    SELECT
        customer_segment,
        aov,
        predicted_clv,
        avg_frequency,
        retention_rate,
        avg_customer_lifespan,
        total_customers
    FROM new_predictive_clv_analysis
),
grand_totals AS (
    SELECT
        SUM(aov * total_customers) / SUM(total_customers)           AS weighted_avg_aov,
        SUM(predicted_clv * total_customers) / SUM(total_customers) AS weighted_avg_clv,
        SUM(avg_frequency * total_customers) / SUM(total_customers) AS weighted_avg_frequency,
        SUM(retention_rate * total_customers) / SUM(total_customers) AS weighted_avg_retention,
        SUM(avg_customer_lifespan * total_customers) / SUM(total_customers) AS weighted_avg_lifespan
    FROM base
)
SELECT
    b.customer_segment                                              AS segment,
    ROUND(b.aov::NUMERIC, 2)                                       AS segment_aov,
    ROUND(b.predicted_clv::NUMERIC, 2)                             AS segment_clv,
    ROUND(b.avg_frequency::NUMERIC, 2)                             AS segment_avg_frequency,
    ROUND(b.retention_rate::NUMERIC, 4)                            AS segment_retention_rate,
    ROUND(b.avg_customer_lifespan::NUMERIC, 2)                     AS segment_avg_lifespan,
    -- Weighted averages of ALL OTHER segments
    ROUND(
        (g.weighted_avg_aov * SUM(b2.total_customers) - b.aov * b.total_customers)
        / NULLIF(SUM(b2.total_customers) - b.total_customers, 0)
    ::NUMERIC, 2)                                                   AS others_aov,
    ROUND(
        (g.weighted_avg_clv * SUM(b2.total_customers) - b.predicted_clv * b.total_customers)
        / NULLIF(SUM(b2.total_customers) - b.total_customers, 0)
    ::NUMERIC, 2)                                                   AS others_clv,
    ROUND(
        (g.weighted_avg_frequency * SUM(b2.total_customers) - b.avg_frequency * b.total_customers)
        / NULLIF(SUM(b2.total_customers) - b.total_customers, 0)
    ::NUMERIC, 2)                                                   AS others_avg_frequency,
    ROUND(
        (g.weighted_avg_retention * SUM(b2.total_customers) - b.retention_rate * b.total_customers)
        / NULLIF(SUM(b2.total_customers) - b.total_customers, 0)
    ::NUMERIC, 4)                                                   AS others_retention_rate,
    ROUND(
        (g.weighted_avg_lifespan * SUM(b2.total_customers) - b.avg_customer_lifespan * b.total_customers)
        / NULLIF(SUM(b2.total_customers) - b.total_customers, 0)
    ::NUMERIC, 2)                                                   AS others_avg_lifespan
FROM base b
CROSS JOIN grand_totals g
CROSS JOIN (SELECT SUM(total_customers) AS total_customers FROM base) b2
GROUP BY
    b.customer_segment, b.aov, b.predicted_clv, b.avg_frequency,
    b.retention_rate, b.avg_customer_lifespan, b.total_customers,
    g.weighted_avg_aov, g.weighted_avg_clv, g.weighted_avg_frequency,
    g.weighted_avg_retention, g.weighted_avg_lifespan
ORDER BY
    CASE b.customer_segment
        WHEN 'Champions'           THEN 1
        WHEN 'Loyal'               THEN 2
        WHEN 'Potential Loyalists' THEN 3
        WHEN 'Recent Customers'    THEN 4
        WHEN 'Promising'           THEN 5
        WHEN 'Need Attention'      THEN 6
        WHEN 'About to Sleep'      THEN 7
        WHEN 'At-Risk'             THEN 8
        WHEN 'Cannot Lose'         THEN 9
        WHEN 'Hibernating'         THEN 10
        WHEN 'Lost'                THEN 11
        ELSE                       12
    END;

DROP TABLE IF EXISTS new_clv_churn_matrix;

CREATE TABLE new_clv_churn_matrix AS
WITH segment_stats AS (
    SELECT
        customer_segment,
        AVG(monetary)                    AS avg_monetary,
        AVG(recency_days)                AS avg_recency,
        AVG(frequency)                   AS avg_frequency,
        COUNT(customer_id)               AS total_customers,
        COUNT(CASE WHEN recency_days > 90 THEN 1 END
        )::NUMERIC / COUNT(customer_id) * 100 AS churn_rate_pct
    FROM new_rfm_segment_analysis
    GROUP BY customer_segment
),
overall AS (
    SELECT AVG(avg_monetary) AS overall_avg_monetary
    FROM segment_stats
)
SELECT
    s.customer_segment,
    ROUND(s.avg_monetary::NUMERIC, 2)      AS avg_monetary,
    ROUND(s.avg_recency::NUMERIC, 0)       AS avg_recency,
    ROUND(s.avg_frequency::NUMERIC, 2)     AS avg_frequency,
    s.total_customers,
    ROUND(s.churn_rate_pct::NUMERIC, 2)    AS churn_rate_pct,
    ROUND(o.overall_avg_monetary::NUMERIC, 2) AS overall_avg_monetary,
    CASE
        WHEN s.churn_rate_pct >= 50 
             AND s.avg_monetary >= o.overall_avg_monetary 
        THEN 'Urgent Win-back'
        WHEN s.churn_rate_pct < 50 
             AND s.avg_monetary >= o.overall_avg_monetary 
        THEN 'Protect'
        WHEN s.churn_rate_pct >= 50 
             AND s.avg_monetary < o.overall_avg_monetary 
        THEN 'Low ROI'
        ELSE 'Monitor'
    END                                    AS quadrant
FROM segment_stats s
CROSS JOIN overall o
ORDER BY churn_rate_pct;

SELECT overall_avg_monetary FROM new_clv_churn_matrix LIMIT 1;