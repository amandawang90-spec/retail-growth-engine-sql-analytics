      <column caption='Top Segment' datatype='integer' name='[Calculation_2711522625523715]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([customer_id (cleaned_retail_main.csv)]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='UK vs Other Countries' datatype='string' name='[Calculation_2711522635853829]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [country (cleaned_retail_main.csv)] = &quot;United Kingdom&quot; THEN &quot;UK&quot; ELSE &quot;Other Countries&quot; END' />
