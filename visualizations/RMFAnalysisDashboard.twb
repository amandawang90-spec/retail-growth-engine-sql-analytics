            <column caption=' churn_rate_bucket' datatype='string' name='[Calculation_2711523285372958]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [churn_rate_pct] &lt; 55 THEN &quot;Low&quot;&#10;ELSEIF [churn_rate_pct] &lt; 75 THEN &quot;Medium&quot;&#10;ELSEIF [churn_rate_pct] &lt; 90 THEN &quot;High&quot;&#10;ELSE &quot;Critical&quot;&#10;END' />
            </column>
            <column-instance column='[churn_rate_pct]' derivation='Attribute' name='[attr:churn_rate_pct:qk]' pivot='key' type='quantitative' />
            <column caption='Churn Rate Pct' datatype='real' name='[churn_rate_pct]' role='measure' type='quantitative' />
            <column caption='Customer Segment (Retention Rates By Rfm Segments.Csv)' datatype='string' name='[customer_segment (retention_rates_by_rfm_segments.csv)]' role='dimension' type='nominal' />
            <column caption='Month Number' datatype='integer' name='[month_number]' role='dimension' type='ordinal' />
