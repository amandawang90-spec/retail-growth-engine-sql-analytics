            <column-instance column='[total_price]' derivation='Sum' name='[sum:total_price:qk]' pivot='key' type='quantitative' />
            <column-instance column='[invoice_date (cleaned_retail_main.csv)]' derivation='Month-Trunc' name='[tmn:invoice_date (cleaned_retail_main.csv):qk]' pivot='key' type='quantitative' />
