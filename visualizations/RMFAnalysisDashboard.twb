      <column caption='Sales CY' datatype='real' name='[Calculation_2711522686664714]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#10;    SUM(&#10;        IF YEAR([invoice_date (cleaned_retail_main.csv)]) = { MAX(YEAR([invoice_date (cleaned_retail_main.csv)])) }&#10;        THEN [total_price]&#10;        END&#10;    )&#10;}' />
      </column>
      <column caption='Sales PY' datatype='real' name='[Calculation_2711522688147467]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#10;    SUM(&#10;        IF YEAR([invoice_date (cleaned_retail_main.csv)]) = { MAX(YEAR([invoice_date (cleaned_retail_main.csv)])) } -1&#10;        THEN [total_price]&#10;        END&#10;    )&#10;}' />
      </column>
      <column caption='% Chg of Sales' datatype='real' default-format='*+0.0% ▲;-0.0% ▼' name='[Calculation_2711522688487436]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(sum([Calculation_2711522686664714])-sum([Calculation_2711522688147467]))/sum([Calculation_2711522688147467])' />
      </column>
      <column caption='Last 12 Months' datatype='boolean' name='[Calculation_2711522689486861]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [invoice_date (cleaned_retail_main.csv)])&#10;&gt;=&#10;DATEADD(&apos;month&apos;,-11, {MAX(DATETRUNC(&apos;month&apos;,[invoice_date (cleaned_retail_main.csv)]))})' />
      </column>
      <column caption='Orders CY' datatype='integer' name='[Calculation_2711522694246415]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#10;    COUNTD(&#10;        IF YEAR([invoice_date (cleaned_retail_main.csv)]) = { MAX(YEAR([invoice_date (cleaned_retail_main.csv)])) }&#10;        THEN [invoice (cleaned_retail_main.csv)]&#10;        END&#10;    )&#10;}' />
      </column>
      <column caption='Orders PY' datatype='integer' name='[Calculation_2711522694905872]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#10;    COUNTD(&#10;        IF YEAR([invoice_date (cleaned_retail_main.csv)]) = { MAX(YEAR([invoice_date (cleaned_retail_main.csv)])) } -1&#10;        THEN [invoice (cleaned_retail_main.csv)]&#10;        END&#10;    )&#10;}' />
