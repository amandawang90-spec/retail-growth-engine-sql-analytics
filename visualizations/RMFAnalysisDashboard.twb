              <calculation class='tableau' formula='IF [churn_rate_pct] &lt; 55 THEN &quot;Low&quot;&#10;ELSEIF [churn_rate_pct] &lt; 75 THEN &quot;Medium&quot;&#10;ELSEIF [churn_rate_pct] &lt; 90 THEN &quot;High&quot;&#10;ELSE &quot;Critical&quot;&#10;END' />
